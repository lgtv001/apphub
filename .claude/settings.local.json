  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd '/c/Users/luisg/Documents/GitHub/apphub/.worktrees/quiebre-contrato' && git add -A 2>/dev/null; if git diff --cached --quiet 2>/dev/null; then jq -n '{\"systemMessage\": \"Subagente terminado (sin cambios nuevos). ¿Continuar al siguiente task?\", \"continue\": false}'; else STAT=$(git diff --cached --stat --no-color 2>/dev/null | tail -1); git commit -m 'wip: task completado - pendiente renombrar' 2>/dev/null; jq -n --arg s \"$STAT\" '{\"systemMessage\": (\"Checkpoint: \" + $s + \". Sugiere nombre de commit (git commit --amend -m) o escribe continuar.\"), \"continue\": false}'; fi",
            "timeout": 30,
            "statusMessage": "Checkpoint: guardando avances del task..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd '/c/Users/luisg/Documents/GitHub/apphub/.worktrees/quiebre-contrato' && git add -A 2>/dev/null; if git diff --cached --quiet 2>/dev/null; then echo '{\"systemMessage\": \"PreCompact: no hay cambios pendientes en el worktree.\"}'; else git commit -m 'wip: auto-save antes de compact' 2>/dev/null && echo '{\"systemMessage\": \"Auto-guardado: cambios commiteados en feature/quiebre-contrato antes de compact.\"}' || echo '{\"systemMessage\": \"Error al intentar auto-save en el worktree.\"}'; fi",
            "statusMessage": "Auto-guardando avances antes de compactar contexto..."
          }
        ]
      }
    ]
